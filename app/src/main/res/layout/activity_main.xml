<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/faucet_bg"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Pairing banner: hidden until a command reports the app is not enabled -->
        <LinearLayout
            android:id="@+id/pairingBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/faucet_banner"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This app is not enabled yet"
                android:textColor="@color/faucet_accent"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Open Minima Core → Apps and enable &quot;Minima Faucet&quot;, then come back."
                android:textColor="@color/faucet_subtext"
                android:textSize="13sp" />

            <Button
                android:id="@+id/openNodeBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Open Minima Core" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MINIMA FAUCET"
            android:textColor="@color/faucet_accent"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get Free Minima"
            android:textColor="@color/faucet_text"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Receive 0.0001 Minima to try out the blockchain."
            android:textColor="@color/faucet_subtext"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Minima Address"
            android:textColor="@color/faucet_subtext"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/addressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste or fetch an address…"
            android:textColorHint="@color/faucet_subtext"
            android:textColor="@color/faucet_text"
            android:background="@color/faucet_input"
            android:padding="14dp"
            android:inputType="text"
            android:maxLines="2" />

        <Button
            android:id="@+id/getAddrBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Get My Address"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/requestBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Request Minima"
            android:backgroundTint="@color/faucet_accent"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/statusBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:padding="14dp"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="The faucet sends a tiny amount of Minima to your node so you can try creating custom tokens and testing transactions."
            android:textColor="@color/faucet_subtext"
            android:textSize="12sp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="eurobuddha · Minima Ecosystem"
            android:textColor="@color/faucet_subtext"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
